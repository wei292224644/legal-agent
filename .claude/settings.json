{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "endsWith(file_path, '.py')",
            "command": "uv run ruff format {{file_path}} && uv run ruff check --fix {{file_path}}"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "prompt",
            "if": "matches(file_path, '\\.env(\\.example)?$')",
            "prompt": "此文件可能包含密钥，确认要继续编辑吗？"
          }
        ]
      }
    ]
  }
}