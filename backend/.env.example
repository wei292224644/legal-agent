# Qwen (Intent Router + Profile Agent)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-flash

# DeepSeek (Heavy Worker)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_THINKING_BUDGET=2000

# Timeouts (seconds)
LLM_TIMEOUT_QWEN=5
LLM_TIMEOUT_DEEPSEEK=8

# Agno HITL / Run 状态持久化
AGNO_DB_URL=postgresql+psycopg://legal:legal@localhost:5432/legal_agent

# Postgres 连接（dev 默认指向 docker-compose）
DATABASE_URL=postgresql+psycopg://legal:legal@localhost:5432/legal_agent
RUN_TIMEOUT=30
PENDING_TTL=300
